# Copy this file to .env.dev or .env.prod outside Git and fill in real values.
# Never commit live credentials.

ENV=dev
APP_ENV=dev

# Database container variables
POSTGRES_DB=bcsentinel
POSTGRES_USER=bcsentinel
POSTGRES_PASSWORD=replace_with_strong_database_password

# SQLAlchemy / psycopg connection string used by the backend
DATABASE_URL=postgresql+psycopg://bcsentinel:replace_with_strong_database_password@postgres:5432/bcsentinel

# Core security
SECRET_KEY=replace_with_a_long_random_secret_key_min_32_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_admin_password_min_16_chars
TOKEN_EXPIRE_MINUTES=60
# DEV/LOCAL may use localhost. In production set the public API base URL and
# explicit website origins, for example:
# APP_BASE_URL=https://api.bcsentinel.com
# CORS_ALLOW_ORIGINS=https://bcsentinel.com,https://www.bcsentinel.com
APP_BASE_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=https://app.example.com
TENANT_REGISTRATION_INVITE_CODE=replace_with_pilot_invite_code
TENANT_REGISTRATION_RATE_LIMIT_ATTEMPTS=5
TENANT_REGISTRATION_RATE_LIMIT_WINDOW_SECONDS=300
SITE_TRANSLATIONS_PATH=/app/landingpage/lang

# Scan runtime safeguards
SCAN_STALLED_AFTER_SECONDS=180
SCAN_MAX_RUNTIME_SECONDS=

# Partner portal / reset mails
PARTNER_RESET_URL_BASE=https://example.com

# SMTP for partner mails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace_with_smtp_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=BCSentinel

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Required Stripe Price IDs for checkout. The Stripe Price amounts must match Product Pricing.
STRIPE_PRICE_ID_ASSESSMENT=
STRIPE_PRICE_ID_VALIDATION_CHECK=
STRIPE_PRICE_ID_MONITORING_MONTHLY=
STRIPE_PRICE_ID_MONITORING_ANNUAL=
# Optional explicit overrides. If unset, the backend derives these from APP_BASE_URL.
# In production, set APP_BASE_URL or all three explicit billing URLs.
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=
BILLING_PORTAL_RETURN_URL=
